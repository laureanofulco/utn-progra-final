{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Compilar Proyecto",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/main.c",
                "${workspaceFolder}/funciones/*.c",
                "${workspaceFolder}/funciones/externas/*.c",
                "-I${workspaceFolder}",
                "-o",
                "${workspaceFolder}/ejecutable"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compila el proyecto completo de forma limpia."
        }
    ],
    "version": "2.0.0"
}